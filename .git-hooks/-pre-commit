#!/bin/bash
# =============================================================
# .git-hooks/pre-commit
# Hook Git : validations avant chaque commit
# =============================================================
# Installation :
#   cp .git-hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
# Ou avec git config :
#   git config core.hooksPath .git-hooks
# =============================================================

echo "🔍 Pre-commit : vérifications en cours..."

ERRORS=0

# ── 1. Vérifier qu'aucun fichier .env n'est commité ─────────
if git diff --cached --name-only | grep -qE "^\.env$|^\.env\.[^e]"; then
    echo "❌ ERREUR : Tentative de commit d'un fichier .env !"
    echo "   Ajoutez .env à .gitignore et retirez-le du stage :"
    echo "   git reset HEAD .env"
    ERRORS=$((ERRORS + 1))
fi

# ── 2. Vérifier qu'aucun secret n'est dans le code ──────────
SECRET_PATTERNS="password\s*=\s*['\"][^'\"]{8,}|api_key\s*=\s*['\"][^'\"]{8,}|secret\s*=\s*['\"][^'\"]"
if git diff --cached -U0 | grep -iE "$SECRET_PATTERNS" | grep "^+" | grep -qv "changeme\|example\|test\|your_"; then
    echo "⚠️  ATTENTION : Des secrets potentiels ont été détectés dans le code."
    echo "   Vérifiez les lignes suivantes :"
    git diff --cached -U0 | grep -iE "$SECRET_PATTERNS" | grep "^+" | head -5
    echo "   Utilisez des variables d'environnement à la place."
    # Warning seulement, pas bloquant
fi

# ── 3. Vérifier la syntaxe Python ───────────────────────────
PYTHON_FILES=$(git diff --cached --name-only | grep "\.py$")
if [ -n "$PYTHON_FILES" ]; then
    for file in $PYTHON_FILES; do
        if [ -f "$file" ]; then
            python3 -m py_compile "$file" 2>/dev/null || {
                echo "❌ ERREUR de syntaxe Python : $file"
                ERRORS=$((ERRORS + 1))
            }
        fi
    done
    if [ $ERRORS -eq 0 ]; then
        echo "✓ Syntaxe Python OK"
    fi
fi

# ── 4. Vérifier que dvc.lock est commité avec dvc.yaml ──────
if git diff --cached --name-only | grep -q "dvc/dvc.yaml"; then
    if ! git diff --cached --name-only | grep -q "dvc/dvc.lock"; then
        echo "⚠️  ATTENTION : dvc.yaml modifié sans commiter dvc.lock"
        echo "   Lancez 'dvc repro' puis ajoutez dvc.lock au commit."
    fi
fi

# ── 5. Vérifier le format des messages de commit ────────────
# (vérifié dans commit-msg hook)

# ── Résultat ────────────────────────────────────────────────
if [ $ERRORS -gt 0 ]; then
    echo ""
    echo "❌ $ERRORS erreur(s) détectée(s). Commit annulé."
    echo "   Corrigez les erreurs et recommencez."
    exit 1
fi

echo "✅ Pre-commit : toutes les vérifications passées !"
exit 0
