#!/bin/bash
# =============================================================
# .git-hooks/commit-msg
# Hook Git : validation du format des messages de commit
# =============================================================
# Format attendu (Conventional Commits) :
#   type(scope): description courte
#
# Types valides :
#   feat     → nouvelle fonctionnalité
#   fix      → correction de bug
#   docs     → documentation
#   chore    → tâches de maintenance
#   refactor → refactorisation
#   test     → ajout/modification de tests
#   perf     → amélioration de performance
#   ci       → intégration continue
#   release  → release
#   merge    → merge de branches
#   model    → versioning du modèle ML
#   experiment → expérience DVC
# =============================================================

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Ignorer les messages de merge automatique
if echo "$COMMIT_MSG" | grep -qE "^Merge (branch|pull request)"; then
    exit 0
fi

# Pattern Conventional Commits
PATTERN="^(feat|fix|docs|chore|refactor|test|perf|ci|release|merge|model|experiment)(\([a-zA-Z0-9_-]+\))?: .{1,100}"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    echo ""
    echo "❌ Format de message de commit invalide !"
    echo ""
    echo "   Format attendu : type(scope): description"
    echo ""
    echo "   Exemples valides :"
    echo "     feat(livres): ajout endpoint recherche avancée"
    echo "     fix(emprunts): correction calcul pénalité"
    echo "     model: SVD v2 — n_components=20"
    echo "     chore: mise à jour dépendances"
    echo ""
    echo "   Votre message : $COMMIT_MSG"
    echo ""
    exit 1
fi

# Vérifier la longueur de la description
DESCRIPTION=$(echo "$COMMIT_MSG" | head -1 | sed 's/^[^:]*: //')
if [ ${#DESCRIPTION} -gt 100 ]; then
    echo "⚠️  Description trop longue (${#DESCRIPTION} caractères, max 100)"
    echo "   Raccourcissez la première ligne et développez dans le corps du message."
fi

echo "✓ Format de commit valide."
exit 0
