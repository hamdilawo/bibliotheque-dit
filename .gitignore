# =====================================================
# .gitignore - Bibliotheque Numerique DIT
# =====================================================

# Environnements virtuels Python
venv/
.venv/
env/
ENV/

# Variables d'environnement & secrets
.env
.env.local
.env.*.local
*.env
!.env.example

# Credentials / cles / tokens (CRITIQUE)
*service-account*.json
*credentials*.json
*-key.json
*-keyfile.json
*.pem
*.key
*.p12
*.pfx
# Cle GCP specifique au projet
dvc-bibliotheque-dit-*.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/

# Bases de donnees locales
*.sqlite3
*.sqlite3-journal
*.db

# Fichiers generes (DVC outputs locaux)
/services/emprunts/data/*.csv
/dvc/data/*.csv
*.pkl
.dvc/cache
.dvc/tmp
dvc/.dvc/cache
dvc/.dvc/tmp

# Frontend / Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
build/
dist/
.next/
.parcel-cache/

# IDE / editeurs
.vscode/
.idea/
*.swp
*.swo
*~
.history/
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Docker volumes locaux
docker-volumes/


.dvc
dvc/
.git-hooks