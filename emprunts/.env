# Variables d'environnement — Bibliothèque DIT
# Copiez ce fichier en .env et adaptez les valeurs

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secret
DB_HOST=localhost
DB_PORT=25432
DB_NAME=emprunts_db

# Django
JWT_SECRET_KEY=votre-cle-secrete-tres-longue-ici
DEBUG=False

# URLs des services (pour docker compose)
SERVICE_LIVRES_URL=http://livres:8001
SERVICE_UTILISATEURS_URL=http://utilisateurs:8002
SERVICE_EMPRUNTS_URL=http://emprunts:8003
